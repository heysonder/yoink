# all vars are optional — yoink works out of the box with youtube (via yt-dlp) for audio
# and public APIs for metadata. adding credentials improves quality and reliability.

# spotify (optional — falls back to public APIs if not set)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# youtube audio source
PIPED_API_URL=             # custom piped instance (optional, yt-dlp is used as fallback)

# lossless audio sources (optional)
DEEZER_MASTER_KEY=         # deezer audio decryption key (required for deezer source)
DEEZER_ARL=                # deezer session cookie — enables lossless audio from deezer
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_ACCESS_TOKEN=
TIDAL_REFRESH_TOKEN=

# captcha (optional — turnstile by cloudflare)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=  # public site key
TURNSTILE_SECRET_KEY=            # secret key for server-side verification

# extras (optional)
SONGLINK_ENABLED=true      # cross-platform link resolution
MUSIXMATCH_TOKEN=          # musixmatch lyrics fallback
LRCLIB_PROXY_URL=          # cloudflare worker proxy for lrclib
ACOUSTID_API_KEY=          # audio fingerprinting
